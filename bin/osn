#!/usr/bin/env python3
"""bin/osn — compatibility entry point for OS3 commands.

All user/LLM commands flow through this entry point + server/cli.py argparse.
Makefile interface is deprecated (T-OSN-W7-OSN-CLI-02 removes it).
RCE surface: 0 — Make var injection stage absent.
"""
import sys
from pathlib import Path

# Ensure the project root is on sys.path so `server` is importable
# regardless of which directory the user invokes bin/osn from.
_PROJECT_ROOT = Path(__file__).resolve().parent.parent
if str(_PROJECT_ROOT) not in sys.path:
    sys.path.insert(0, str(_PROJECT_ROOT))

from server.cli import main  # noqa: E402

sys.exit(main(sys.argv[1:]))
